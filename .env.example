# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_postgres

# Keycloak DB
KC_DB_PASSWORD=changeme_keycloak

# BFF DB
BFF_DB_PASSWORD=changeme_bff

# API DB
API_DB_PASSWORD=changeme_api

# Keycloak admin
KC_ADMIN=admin
KC_ADMIN_PASSWORD=changeme_admin

# OAuth2 BFF client secret (doit correspondre au secret configuré dans Keycloak)
BFF_CLIENT_SECRET=changeme_bff_secret

# URLs Keycloak
# URL interne Docker (BFF et API → Keycloak sur backend-net)
KEYCLOAK_INTERNAL_URI=http://keycloak:8080
# URL publique (browser → Keycloak via Nginx ; aussi dans le claim 'iss' des tokens)
KEYCLOAK_PUBLIC_URI=https://localhost:8443
KEYCLOAK_PUBLIC_ISSUER=https://localhost:8443/realms/my-realm
